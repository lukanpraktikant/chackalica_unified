# ============ friendy_chachkalica trainer service — environment ============
# Copy this file to `.env` (which is git-ignored) and edit the values for THIS
# machine before running `docker compose up`. Read automatically by
# `docker compose` in this directory.
#
#     cp .env.example .env   &&   $EDITOR .env

# ─────────────────────────── MUST EDIT PER MACHINE ───────────────────────────
# Where the shared data physically lives ON THE HOST. This is the `data/`
# directory of your Django (chachkalica) checkout — the trainer and Django share
# it on disk. There is NO default: `docker compose up` fails fast if this is
# unset. Point it at the real path on this machine, e.g.:
#     HOST_DATA_DIR=/home/<you>/chachkalica/data
HOST_DATA_DIR=/CHANGE/ME/chachkalica/data

# ───────────────────────────── usually fine as-is ─────────────────────────────
# The path the config YAMLs reference internally. Django generates absolute
# paths from its own BASE_DIR + /data. The chachkalica web/worker containers run
# with WORKDIR /app, so BASE_DIR=/app and every baked path is /app/data/...  The
# trainer must expose the shared data at THIS SAME path or those absolute paths
# won't resolve (you get HTTP 400 "config not found"). Backed by HOST_DATA_DIR.
# Only change this if your Django containers use a different WORKDIR/BASE_DIR.
TRAINER_DATA_DIR=/app/data

# Port the service listens on, published to the host. MUST equal the port in
# Django admin → Training settings → service_base_url (host.docker.internal:8200).
FC_PORT=8200

# Max concurrent training/eval jobs. 1 = single-GPU safety; a second launch
# while one is active gets HTTP 409 "trainer busy".
FC_MAX_CONCURRENT=1

# Shared-memory (/dev/shm) size for the container. PyTorch DataLoader workers
# need this; Docker's 64 MB default makes training hang. Raise for more workers.
FC_SHM_SIZE=2gb

# Run the container as the same user as the chachkalica web/worker containers so
# run outputs under data/training/ have matching ownership. Those containers run
# as root (UID 0), so the trainer defaults to root too. If your chachkalica stack
# runs as a non-root user, set these to that user's UID/GID instead
# (`id -u` / `id -g`).
FC_UID=0
FC_GID=0
