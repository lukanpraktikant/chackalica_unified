# ================= Unified Chachkalica stack — environment =================
# Copy to .env and adjust. All values have sane defaults in docker-compose.yml,
# so an empty .env still works. These are read by `docker compose` for ${VAR}
# interpolation in the compose file.

# ── Trainer (friendy_chachkalica) ──────────────────────────────────────────
# Port the FastAPI trainer listens on (host + container). Django reaches it
# in-network at http://trainer:8200 regardless of this, but keep it 8200 so the
# published host port matches the TrainingSettings default for standalone use.
FC_PORT=8200
# Refuse a second concurrent training launch with HTTP 409 (single-GPU safety).
FC_MAX_CONCURRENT=1
# /dev/shm size for PyTorch DataLoader workers. Bump for many workers / big batches.
FC_SHM_SIZE=2gb

# ── Notes ───────────────────────────────────────────────────────────────────
# * Postgres/Redis credentials and Django settings are baked into the compose
#   `environment:` blocks (fleet/fleet) and the chachkalica/.env consumed inside
#   the web/worker containers. Change them there if needed.
# * GPU: uncomment the `deploy:` block on the `trainer` service in
#   docker-compose.yml (requires the NVIDIA Container Toolkit on the host).
