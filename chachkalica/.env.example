# Template for the fleet app's environment. Copy to .env and edit:
#   cp .env.example .env
# Then generate a real secret key (URL-safe: no $/# that dotenv or compose
# would try to interpolate):
#   .venv/bin/python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Defaults below assume the web process + worker run ON THE HOST against the
# compose-managed Postgres + Redis. Inside docker compose, the compose file's
# environment: block overrides these.

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Postgres (matches docker-compose service) ---
POSTGRES_DB=fleet
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# --- Redis / RQ ---
REDIS_URL=redis://127.0.0.1:6379/0
RQ_ASYNC=true

# --- Fleet ---
# Host runs: localhost. Inside docker compose: host.docker.internal.
FLEET_LS_HOST=localhost
